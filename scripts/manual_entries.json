    "linuxserver": {
      "name": "LinuxServer.io",
      "image_patterns": ["lscr.io/linuxserver/", "linuxserver/", "ghcr.io/linuxserver/"],
      "uid_env": "PUID",
      "gid_env": "PGID",
      "umask_env": "UMASK",
      "default_uid": "911",
      "default_gid": "911",
      "needs_puid": true
    },
